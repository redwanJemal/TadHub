{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/saas-platform",
    "Audience": "saas-api",
    "ClientId": "saas-api",
    "ClientSecret": "",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": true,
    "ValidateAudience": true
  },

  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "saaskit",
    "Password": "",
    "VirtualHost": "/"
  },

  "Storage": {
    "Endpoint": "localhost:9000",
    "AccessKey": "",
    "SecretKey": "",
    "UseSSL": false,
    "DefaultBucket": "saaskit-uploads"
  },

  "Meilisearch": {
    "Url": "http://localhost:7700",
    "ApiKey": ""
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 5
  },

  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "SaaS Kit"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4000"
    ]
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "Window": 60,
    "QueueLimit": 10
  },

  "Features": {
    "EnableSwagger": true,
    "EnableHangfireDashboard": true,
    "EnableHealthChecks": true
  },

  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": "",
    "Enabled": false
  }
}
